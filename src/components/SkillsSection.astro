---
import skills from '@/assets/data/skills.json'

interface Props {
	title: string
}

const { title } = Astro.props
---
<section id="skills" class="py-8 scroll-mt-20 opacity-0">
  <h2 class="mb-12 text-center text-3xl font-medium text-grayblue-900 dark:text-grayblue-100 gsap-fade-up transition-colors duration-300">{title}</h2>
  <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
    {skills.map((skill: string) => (
      <div class="skill-card rounded-lg bg-white dark:bg-grayblue-800 border border-grayblue-200 dark:border-grayblue-700 p-6 text-center shadow-lg transition-all duration-300 hover:bg-grayblue-50 dark:hover:bg-grayblue-700 hover:scale-110 flex items-center justify-center">
        <p class="text-lg text-center wrap-break-word hyphens-auto font-medium text-grayblue-800 dark:text-grayblue-200">{skill}</p>
      </div>
    ))}
  </div>
</section>
