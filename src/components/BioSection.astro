---

interface Props {
	content: {
		title: string
		paragraphs: string[]
	}
}

const { content } = Astro.props
---

<section id="bio" class="py-8 scroll-mt-20 opacity-0">
  <h2 class="mb-12 text-center text-3xl font-medium text-grayblue-900 dark:text-grayblue-100 gsap-fade-up transition-colors duration-300">{content.title}</h2>
  <div class="mx-auto bg-white dark:bg-grayblue-800 p-8 rounded-lg shadow-lg border border-grayblue-200 dark:border-grayblue-700 gsap-fade-up transition-colors duration-300">
    {
      content.paragraphs.map((paragraph, index) => (
        <p class={`text-lg leading-relaxed text-grayblue-700 dark:text-grayblue-300 gsap-fade-up transition-colors duration-300${index > 0 ? " mt-4" : ""}`}>
          {paragraph}
        </p>
      ))
    }
  </div>
</section>
